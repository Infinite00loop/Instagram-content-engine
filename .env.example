# Primary LLM model to use (e.g., gemini/gemini-2.5-flash, gpt-4o, etc.)
MODEL='gemini/gemini-2.5-flash'

# API Key for Google Gemini (required if using gemini models)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# API Key for Serper.dev (required for web search tools)
# Get a free key at https://serper.dev/
SERPER_API_KEY=YOUR_SERPER_API_KEY

# API Key for Browserless.io (required for web scraping tools)
# Get a free key at https://www.browserless.io/
BROWSERLESS_API_KEY=YOUR_BROWSERLESS_API_KEY